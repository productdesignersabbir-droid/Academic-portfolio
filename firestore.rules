rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: blogs
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, max 100 chars)
    //   - desc: string (required, max 300 chars)
    //   - content: string (required, max 50000 chars)
    //   - date: string (required, max 50 chars)
    //   - readTime: string (required, max 50 chars)
    //   - createdAt: timestamp (required)
    //
    // Collection: settings
    // Document ID: specific string (e.g., 'cv')
    // Fields:
    //   - url: string (required, valid URL)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // The user email from the runtime context is the admin
      return isAuthenticated() && request.auth.token.email == "productdesigner.sabbir@gmail.com" && request.auth.token.email_verified == true;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
             request.resource.data[field].size() >= minLen &&
             request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidBlog() {
      return hasOnlyAllowedFields(['title', 'desc', 'content', 'date', 'readTime', 'createdAt']) &&
             isValidString('title', 1, 100) &&
             isValidString('desc', 1, 300) &&
             isValidString('content', 1, 50000) &&
             isValidString('date', 1, 50) &&
             isValidString('readTime', 1, 50) &&
             request.resource.data.createdAt is timestamp;
    }

    function isValidSetting() {
      return hasOnlyAllowedFields(['url']) &&
             isValidUrl(request.resource.data.url) &&
             request.resource.data.url.size() <= 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /blogs/{blogId} {
      // Anyone can read blogs
      allow read: if true;
      // Only admin can create/update/delete
      allow create: if isAdmin() && isValidBlog();
      allow update: if isAdmin() && isValidBlog();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      // Anyone can read settings
      allow read: if true;
      // Only admin can create/update/delete
      allow create: if isAdmin() && isValidSetting();
      allow update: if isAdmin() && isValidSetting();
      allow delete: if isAdmin();
    }
  }
}
